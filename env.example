# ───────────────────────────────────────────────────────────────
# Pishico Bot — Variables de entorno
# ───────────────────────────────────────────────────────────────
#
# Copiá este archivo a `.env` y ajustá los valores:
#   cp .env.example .env
#
# El archivo `.env` NO debe subirse al repositorio (agregalo al .gitignore).
# El archivo `.env.example` SÍ se sube (sirve como plantilla).
# ───────────────────────────────────────────────────────────────


# ── Base de datos ─────────────────────────────────────────────────────────────
# DATABASE_URL acepta dos formatos:
#
#   1) SQLite (desarrollo local, archivo en disco):
#      DATABASE_URL=sqlite:///actions/progress.db
#
#   2) PostgreSQL (producción AWS RDS):
#      DATABASE_URL=postgresql://usuario:password@host:5432/nombre_bd
#
# Para AWS RDS PostgreSQL, después de crear la instancia tendrás:
#   - Endpoint: pishico-db.xxxxx.us-east-1.rds.amazonaws.com
#   - Port: 5432
#   - Usuario maestro y contraseña que definiste al crear la instancia
#   - Nombre de la BD inicial
#
# Ejemplo armado:
#   DATABASE_URL=postgresql://pishico:miPassword2026@pishico-db.xxxxx.us-east-1.rds.amazonaws.com:5432/pishico
#
DATABASE_URL=sqlite:///actions/progress.db


# ── Servicio RAG (cliente HTTP) ───────────────────────────────────────────────
# URL del servicio RAG independiente. En desarrollo local apunta a localhost,
# en producción puede ser otra IP o nombre interno del VPC de AWS.
RAG_SERVICE_URL=http://127.0.0.1:8001

# Timeout en segundos para las llamadas HTTP al RAG. Si tarda más que esto,
# el bot cae al placeholder textual sin colgarse.
RAG_TIMEOUT=5.0


# ── Sistema de scoring (evaluación de aprendizaje) ────────────────────────────
# Pesos para el cálculo de dominio por palabra. Reflejan la dificultad
# relativa de cada modo en la adquisición de vocabulario L2.

# Producción: el alumno ve la palabra en español y produce la shipibo.
# Más difícil, mayor peso.
SCORING_PESO_PRODUCCION=2.0

# Receptivo: el alumno ve la palabra shipibo y produce el español.
# Más fácil, menor peso.
SCORING_PESO_RECEPTIVO=1.0

# Penalización por usar pista (resta del acierto positivo).
SCORING_PENALIZA_PISTA=0.5

# Penalización por respuesta incorrecta (resta directa al score).
SCORING_PENALIZA_ERROR=1.0

# Umbrales para clasificar el estado de dominio de cada palabra (0-100).
SCORING_UMBRAL_DOMINADO=71
SCORING_UMBRAL_APRENDIENDO=31


# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
